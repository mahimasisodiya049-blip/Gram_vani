# Bhashini ULCA API Configuration
# Get these from https://bhashini.gov.in/
BHASHINI_API_KEY=your-bhashini-api-key-here
BHASHINI_USER_ID=your-bhashini-user-id-here

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=gram-vani-documents

# Bedrock Configuration
BEDROCK_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_LLM_MODEL_ID=anthropic.claude-v2

# Vector Database Configuration (Optional)
VECTOR_DB_URL=your-vector-db-url
VECTOR_DB_API_KEY=your-vector-db-api-key

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
